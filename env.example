# LLM API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Persistent memory embeddings reuse existing model API keys.
# Priority: OpenAI (OPENAI_API_KEY) -> Gemini (GOOGLE_API_KEY) -> Ollama (OLLAMA_BASE_URL)
# No additional memory-specific API keys required.

# Data Provider Selection
# Controls which provider backs all finance tools. Defaults to fdatasets.
#   fdatasets  - Financial Datasets API (current behavior, paid)
#   composite  - Free composite stack: SEC EDGAR + Finnhub + FMP + CoinGecko (US only)
#   edgar      - SEC EDGAR only (fundamentals/filings/insiders, US only, free)
#   finnhub    - Finnhub only (prices/news/earnings, free tier 60 req/min)
#   fmp        - Financial Modeling Prep only (free tier 250 req/day)
DATA_PROVIDER=fdatasets

# Stock Market API Keys (only the ones used by your DATA_PROVIDER need to be set)
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key
FINNHUB_API_KEY=your-finnhub-api-key
FMP_API_KEY=your-fmp-api-key

# SEC EDGAR fair-use header — required when DATA_PROVIDER includes edgar/composite.
# SEC requires identification: "Your Name your-email@example.com"
EDGAR_USER_AGENT=Your Name your-email@example.com

# Web Search API Keys (Exa → Perplexity → Tavily)
EXASEARCH_API_KEY=your-exa-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
TAVILY_API_KEY=your-tavily-api-key

# X/Twitter API (enables x_search tool for public sentiment research)
X_BEARER_TOKEN=your-X-bearer-token

# LangSmith 
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=false
